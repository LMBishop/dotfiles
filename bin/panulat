#!/bin/bash

podman run \
	-v ${PWD}/pages:/app/pages \
	-v ${PWD}/static:/app/static \
	-v ${PWD}/views:/app/views \
	-v ${PWD}/build:/app/build:rw \
	-p 3000:3000 \
	repo.leonardobishop.net/docker/panulat:1.7.2 \
	--staticDir /app/static \
	--viewsDir /app/views \
	--pagesDir /app/pages \
	--buildDir /app/build \
	"$@"
